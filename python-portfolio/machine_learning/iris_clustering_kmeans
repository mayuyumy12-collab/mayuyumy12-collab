{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNCLoLAXniEl2lRHcl1BrZt"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["**Clustering**\\\n","Use K-Means clustering to divide the Iris dataset into three clusters."],"metadata":{"id":"jFlyEiHTIJIi"}},{"cell_type":"code","source":["from sklearn import datasets\n","from sklearn.cluster import KMeans\n","import matplotlib.pyplot as plt\n","\n","# read the Iris dataset\n","iris=datasets.load_iris()\n","X=iris.data\n","\n","# building and training a K‑Means clustering model\n","kmeans=KMeans(n_clusters=3, random_state=42)\n","kmeans.fit(X)\n","\n","# display the clustering results in a scatter plot\n","labels=kmeans.labels_\n","iris=['Setosa', 'Versicolor', 'Virginica']\n","\n","for i in range(3):\n","  cluster_points=X[labels==i]  # obtain the indices of the data points belonging to cluster i and select the corresponding rows from X\n","  plt.scatter(cluster_points[:, 0], cluster_points[:, 1], label=iris[i])\n","\n","plt.legend()\n","plt.title('K-Means Clustering of Iris Dataset')\n","plt.xlabel('Sepal Length(cm)')\n","plt.ylabel('Sepal Width(cm)')\n","\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":472},"id":"xv3Uvl73I5un","executionInfo":{"status":"ok","timestamp":1773323237068,"user_tz":-540,"elapsed":450,"user":{"displayName":"まゆゆ","userId":"17791087719490621282"}},"outputId":"867a298f-c298-425d-e2ed-10cd941029c3"},"execution_count":3,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]}]}